#!name=DeepSeek 余额监控
#!desc=手动查询 DeepSeek API 账户总余额、充值余额、赠送余额和可用状态；规则分流失败时自动通过指定策略组重试。
#!system=ios
#!arguments=API_KEY:replace_with_your_key,PROXY_GROUP:Proxy,LOW_BALANCE:5
#!arguments-desc=API_KEY：填写 DeepSeek 官方 API Key。\nPROXY_GROUP：备用策略组名称，默认 Proxy。\nLOW_BALANCE：低余额提醒阈值，默认 5。

[Panel]
DeepSeek余额监控 = title="DeepSeek 余额",content="点击刷新查询",style=info,script-name=DeepSeek余额监控V3

[Script]
DeepSeek余额监控V3 = type=generic,script-path=https://raw.githubusercontent.com/AMEKIN/Surge/refs/heads/main/scripts/deepseek-balance.js?v=20260723v3,argument=API_KEY={{{API_KEY}}}&PROXY_GROUP={{{PROXY_GROUP}}}&LOW_BALANCE={{{LOW_BALANCE}}},script-update-interval=3600,timeout=12,engine=webview